# Local Ollama configuration for server-side RAG/search.
# The current Montgomery County calls-for-service dataset is public, so local
# Ollama indexing and search may cover the full fetched dataset.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
RAG_INDEX_SCOPE=all_public_records
RAG_DATABASE_PATH=data/rag/rag.sqlite
